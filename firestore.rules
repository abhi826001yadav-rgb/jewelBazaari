rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'abhi826001yadav@gmail.com',
          'priankasuresh97@gmail.com'
        ];
    }

    function vendorData(vendorId) {
      return get(/databases/$(database)/documents/vendors/$(vendorId)).data;
    }

    function isApprovedVendorOwner(vendorId) {
      return request.auth != null
        && vendorId is string
        && vendorId.size() > 0
        && exists(/databases/$(database)/documents/vendors/$(vendorId))
        && vendorData(vendorId).uid == request.auth.uid
        && vendorData(vendorId).status == 'approved';
    }

    function hasValidProductFields(data) {
      return data.name is string && data.name.size() > 0
        && data.price is number && data.price > 0
        && data.category is string && data.category.size() > 0
        && data.imageUrl is string && data.imageUrl.size() > 0
        && data.vendorId is string && data.vendorId.size() > 0;
    }

    function currentEpochDay() {
      return int(request.time.toMillis() / 86400000);
    }

    function hasValidCustomerQueryFields(data) {
      return data.name is string && data.name.size() >= 2
        && data.email is string
        && data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && data.phone is string && data.phone.size() >= 10
        && data.subject is string && data.subject.size() >= 3
        && data.message is string && data.message.size() >= 10;
    }

    function isValidCustomerQuery(data, queryId) {
      return hasValidCustomerQueryFields(data)
        && data.epochDay is int
        && data.epochDay == currentEpochDay()
        && data.createdAt == request.time
        && queryId == data.email.lower() + '_' + string(data.epochDay);
    }

    match /vendors/{vendorId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && !request.resource.data.keys().hasAny(['vendorPasswordHash']);
      allow update: if isAdmin()
        && !request.resource.data.keys().hasAny(['vendorPasswordHash']);
      allow delete: if false;
    }

    match /vendorIds/{vendorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/vendorIds/$(vendorId));
      allow update, delete: if false;
    }

    match /vendorCredentials/{vendorId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/vendors/$(vendorId))
        && get(/databases/$(database)/documents/vendors/$(vendorId)).data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'vendorPasswordHash'])
        && request.resource.data.vendorPasswordHash is string
        && request.resource.data.vendorPasswordHash.size() == 64
        && !exists(/databases/$(database)/documents/vendorCredentials/$(vendorId));
      allow update, delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin()
        || (hasValidProductFields(request.resource.data)
          && isApprovedVendorOwner(request.resource.data.vendorId));
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['addToCartCount'])
        || (hasValidProductFields(request.resource.data)
          && resource.data.vendorId == request.resource.data.vendorId
          && isApprovedVendorOwner(resource.data.vendorId));
      allow delete: if isAdmin()
        || isApprovedVendorOwner(resource.data.vendorId);
    }

    match /customerQueries/{queryId} {
      allow read: if isAdmin();
      allow create: if isValidCustomerQuery(request.resource.data, queryId)
        && !exists(/databases/$(database)/documents/customerQueries/$(queryId));
      allow update: if isAdmin() && hasValidCustomerQueryFields(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}