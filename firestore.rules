rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasValidProductFields(data) {
      return data.name is string && data.name.size() > 0
        && data.price is number && data.price > 0
        && data.category is string && data.category.size() > 0
        && data.imageUrl is string && data.imageUrl.size() > 0
        && data.vendorId is string && data.vendorId.size() > 0;
    }

    function isAddToCartOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['addToCartCount'])
        && request.resource.data.addToCartCount == resource.data.addToCartCount + 1;
    }

    function currentEpochDay() {
      return int(request.time.toMillis() / 86400000);
    }

    function hasValidCustomerQueryFields(data) {
      return data.name is string && data.name.size() >= 2
        && data.email is string
        && data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && data.phone is string && data.phone.size() >= 10
        && data.subject is string && data.subject.size() >= 3
        && data.message is string && data.message.size() >= 10;
    }

    function isValidCustomerQuery(data, queryId) {
      return hasValidCustomerQueryFields(data)
        && data.epochDay is int
        && data.epochDay == currentEpochDay()
        && data.createdAt == request.time
        && queryId == data.email.lower() + '_' + string(data.epochDay);
    }

    // Password-gated vendor + admin portals write from the browser without Firebase Auth.
    match /products/{productId} {
      allow read: if true;
      allow create: if hasValidProductFields(request.resource.data);
      allow update: if hasValidProductFields(request.resource.data) || isAddToCartOnlyUpdate();
      allow delete: if true;
    }

    match /customerQueries/{queryId} {
      allow read: if true;
      allow create: if isValidCustomerQuery(request.resource.data, queryId)
        && !exists(/databases/$(database)/documents/customerQueries/$(queryId));
      allow update: if hasValidCustomerQueryFields(request.resource.data);
      allow delete: if true;
    }

    // Legacy vendor-registration collections — no longer used by the app.
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if false;
    }

    match /vendorIds/{vendorId} {
      allow read: if true;
      allow write: if false;
    }

    match /vendorEmails/{email} {
      allow read: if true;
      allow write: if false;
    }

    match /vendorCredentials/{vendorId} {
      allow read, write: if false;
    }
  }
}