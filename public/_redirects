# jewelBazaari — Cloudflare Pages redirects
# Format: <source> <destination> [status]
# NOTE: Do NOT add /page -> /page.html rules — they loop with .html URL stripping on Cloudflare.

# Home aliases
/home              /index.html    301
/index             /index.html    301
/home/             /index.html    301

# Private portals (extensionless local + production URLs)
/admin             /admin.html    301
/admin/            /admin.html    301
/vendor-upload     /vendor-upload.html    301
/vendor-upload/    /vendor-upload.html    301

# Order tracking
/track-order       /track-order.html    301
/track-order/      /track-order.html    301

# Contact aliases
/contact           /query.html    301
/contact-us        /query.html    301
/contact/          /query.html    301
/contact-us/       /query.html    301

