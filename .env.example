# Cloudinary public settings for jewelBazaari image uploads.
# Copy values into public/js/utils/cloudinary-config.js (vanilla JS deployment).
# If you migrate to Vite, these map to import.meta.env automatically.
#
# NEVER add CLOUDINARY_API_SECRET here — use an unsigned upload preset only.

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=