# jewelBazaari — Cloudflare Pages redirects
# Format: <source> <destination> [status]
#
# CRITICAL: Cloudflare Pages already:
#   1) serves foo.html at /foo (pretty URLs)
#   2) 308-redirects /foo.html → /foo
# Never add /page → /page.html 301s — they create ERR_TOO_MANY_REDIRECTS loops
# (seen on vendor-upload, admin, track-order).

# Home aliases (extensionless destinations avoid fighting CF's .html stripping)
/home              /             301
/index             /             301
/home/             /             301

# Contact aliases → clean path (CF serves query.html at /query)
/contact           /query        301
/contact-us        /query        301
/contact/          /query        301
/contact-us/       /query        301

# About aliases → clean path (CF serves about-us.html at /about-us)
/about             /about-us     301
/about/            /about-us     301

# Legacy / removed paths
/diamond%20copy.html    /diamond    301